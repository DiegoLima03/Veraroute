# Plantilla de variables de entorno - copiar a config/.env y rellenar
# config/.env NO se commitea (está en .gitignore).

# --- Base de datos ---
DB_HOST=127.0.0.1
DB_PORT=3308
DB_NAME=gestorrutas
DB_USER=root
DB_PASS=

# --- Aplicacion ---
# APP_DEBUG=1  -> muestra errores en pantalla (solo desarrollo)
# APP_DEBUG=0  -> errores silenciados, se loguean a logs/error.log
APP_DEBUG=0

# --- Google Geocoding API (opcional, solo para geocode_clientes_bd.py) ---
GOOGLE_API_KEY=
